# CarCam Pro — EditorConfig
# https://editorconfig.org
# Applies across Xcode, VS Code, JetBrains IDEs, etc.

root = true

[*]
charset                   = utf-8
end_of_line               = lf
insert_final_newline      = true
trim_trailing_whitespace  = true
indent_style              = space
indent_size               = 4

[*.{swift,m,mm,h,c,cpp}]
indent_size               = 4
max_line_length           = 120

[*.{json,yml,yaml,xml,plist,entitlements,xcconfig}]
indent_size               = 2

[*.md]
trim_trailing_whitespace  = false

[Makefile]
indent_style              = tab

[*.{pbxproj,xcscheme}]
indent_style              = tab
indent_size               = 2
