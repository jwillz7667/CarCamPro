# ─────────────────────────────────────────────────────────────
#  CarCam Pro — Backend environment template
#  Copy to `.env` (ignored by git) and fill in real values.
# ─────────────────────────────────────────────────────────────

# Node / server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info                # trace | debug | info | warn | error | fatal

# Database — Postgres 16 with PostGIS
DATABASE_URL=postgresql://carcam:carcam@localhost:5432/carcam?schema=public
# Shadow DB URL (Prisma migrations) — optional in dev.
# SHADOW_DATABASE_URL=postgresql://carcam:carcam@localhost:5432/carcam_shadow?schema=public

# Redis — used for refresh-token revocation cache, rate limits, idempotency
REDIS_URL=redis://localhost:6379/0

# JWT — used for access tokens (short-lived). Generate via:
#   openssl rand -base64 64
JWT_ACCESS_SECRET=REPLACE_WITH_64_BYTE_BASE64
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ISSUER=https://api.carcampro.app
JWT_AUDIENCE=carcam-ios

# Apple — Sign in with Apple verification (no secrets required; we verify the
# identity token's signature against Apple's published JWKS). Set these to
# match your iOS bundle.
APPLE_APP_BUNDLE_ID=Res.CarCam-Pro

# Apple — App Store Server API (server-side receipt verification + webhook).
# Generate the API key at App Store Connect → Users and Access → Keys → In-App Purchase.
APPLE_ASSA_KEY_ID=
APPLE_ASSA_ISSUER_ID=
APPLE_ASSA_PRIVATE_KEY=        # -----BEGIN PRIVATE KEY----- … base64
APPLE_ASSA_ENVIRONMENT=Sandbox # Sandbox | Production

# Object storage — S3-compatible. Backblaze B2 or Cloudflare R2 recommended.
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET_CLIPS=carcam-clips
S3_BUCKET_THUMBS=carcam-thumbs
S3_BUCKET_REPORTS=carcam-reports
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123
S3_FORCE_PATH_STYLE=true       # true for MinIO / R2, false for AWS
S3_PRESIGN_TTL=900             # presigned URL lifetime (seconds)

# Security
ACCESS_ORIGINS=https://app.carcampro.app,https://admin.carcampro.app
RATE_LIMIT_MAX=120             # requests per minute per IP
TRUST_PROXY=true               # set when behind Railway / Cloudflare
